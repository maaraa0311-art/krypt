# ── PostgreSQL холболт ──────────────────────────────────────
# Локал жишээ:
DATABASE_URL=postgresql://postgres:password@localhost:5432/krypt
# Хостинг (Railway/Render/Neon) дээр SSL шаардвал:
# PGSSL=true

# ── Аюулгүйн түлхүүр (заавал солино!) ───────────────────────
# Урт, санамсаргүй утга. Жишээ үүсгэх:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ── Сервер ──────────────────────────────────────────────────
PORT=4000

# ── CORS ────────────────────────────────────────────────────
# Хөгжүүлэлтэд * (бүгд). Production-д өөрийн домейнээ заана:
# CORS_ORIGIN=https://tani-domain.mn
CORS_ORIGIN=*
